{
  "name": "rafter-promo-60s",
  "version": "0.1.0",
  "private": true,
  "description": "60s Rafter promo video — Remotion composition. Renders headless via npx remotion render.",
  "scripts": {
    "studio": "remotion studio",
    "render": "remotion render Promo60-16x9 ../build/promo-60s-raw.mp4",
