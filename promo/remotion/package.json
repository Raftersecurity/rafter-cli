    "@remotion/media-utils": "4.0.380",
    "@remotion/zod-types": "4.0.380",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.380",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "typescript": "5.6.3"
  }
}
