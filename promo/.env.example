# Rafter promo video build — required API keys
# Copy to .env and fill in. .env is gitignored.

# HeyGen (voiceover synthesis + optional avatar host beat)
# Get key at https://app.heygen.com → Profile → API Tokens.
# A "Creator" tier or higher is required for commercial/promo use.
HEYGEN_API_KEY=

# Voice ID — pick from https://docs.heygen.com/reference/list-voices-v2
# Default: "Daniel - Conversational" (en-US, male, warm baritone). Override
# in .env if you've cloned a Rome voice or picked a different read.
HEYGEN_VOICE_ID=1bd001e7e50f421d891986aad5158bc8

# Avatar ID — OPTIONAL. If set, scripts/render-host.sh renders a talking-head
# bookend that swaps in for the CTA beat (0:55–1:00). Leave blank to keep the
# pure-motion-graphic CTA we already have.
HEYGEN_AVATAR_ID=

# Suno (music bed) — still required; HeyGen does not compose music.
# Get key at https://suno.ai → API access (commercial tier required for ads).
SUNO_API_KEY=

# Optional: freesound.org API for SFX manifest verification (CC0 only).
FREESOUND_API_KEY=
